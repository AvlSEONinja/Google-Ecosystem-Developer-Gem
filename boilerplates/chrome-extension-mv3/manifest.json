{
  "manifest_version": 3,
  "name": "Google Ecosystem Gem Template - Chrome Extension",
  "version": "1.0.0",
  "description": "Baseline MV3 template managed by Google Gem workflow.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
